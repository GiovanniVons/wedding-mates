# ============================================================================
# Wedding Mates -- environment variables
# Copy this file to .env.local and fill in real values.
# .env.local is gitignored; .env.example is committed as the reference.
# ============================================================================

# --- Site ---------------------------------------------------------------
# The canonical public origin. Used for cross-origin links (auth emails,
# Stripe callbacks). On localhost the request origin is used instead, so this
# only needs the real value in deployed environments.
NEXT_PUBLIC_SITE_URL=https://letsgetwed.com.au

# --- Supabase (REQUIRED for auth) ---------------------------------------
# Client decision: provision a Supabase project, apply supabase/migrations,
# then paste the values here. Until then, .env.local uses safe placeholders so
# the app builds (it just cannot authenticate).
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Server-only. NEVER expose to the browser. Used by the Stripe webhook to grant
# course access and by admin operations. Bypasses RLS.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- DEV-ONLY preview gating bypass -------------------------------------
# OFF by default. Set to off-for-preview ONLY in a local .env.local to preview
# the gated /course UI before Supabase exists. It is automatically IGNORED the
# moment a real NEXT_PUBLIC_SUPABASE_URL is present, so it can never weaken
# production. Leave unset (or any other value) for normal gating.
# NEXT_PUBLIC_PREVIEW_GATING=off-for-preview

# --- DEMO mode (no-account course walkthrough) --------------------------
# OFF by default. Set to "on" to open the gated /course as a public DEMO with
# NO account, EVEN with real Supabase set -- for a demo/showcase deploy or a
# local walkthrough so prospects + the client can experience the course without
# Stripe + signup. The course shows a clear "Demo preview" banner, stays
# noindex, and progress is per-session. WARNING: turning this on makes the
# course content publicly reachable without payment -- never set it on the live
# selling storefront. NEXT_PUBLIC_* vars are build-time, so changing it needs a
# rebuild/redeploy. Leave unset for the real gate.
# NEXT_PUBLIC_DEMO_MODE=on

# --- Stripe (LATER BATCH -- not used yet) -------------------------------
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# --- Resend / transactional email (LATER BATCH -- not used yet) ---------
RESEND_API_KEY=re_xxx
EMAIL_FROM="Wedding Mates <hello@letsgetwed.com.au>"
SUPPORT_EMAIL=sarah@letsgetwed.com.au
SUPPORT_WHATSAPP=0410820300
ONBOARDING_CALL_URL=https://calendly.com/letsgetwed/onboarding
